{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "installCommand": "cd app && bun install",
    "buildCommand": "cd app && bun run build",
    "outputDirectory": "app/dist",
    "rewrites": [
        {
            "source": "/((?!.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}